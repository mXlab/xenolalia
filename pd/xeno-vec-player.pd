#N canvas 200 100 500 400 12;
#X text 10 10 xeno-vec-player;
#X text 10 25 Send pre-generated encoder vectors to the sonoscope via OSC.;
#X text 10 40 Requires mrpeach (oscformat \, netsend). Click CONNECT before use.;
#X obj 350 165 text;
#X obj 10 75 loadbang;
#X msg 10 100 read ../analysis/all_vecs.txt;
#X obj 20 155 bng 30 250 50 0 empty empty SEND 17 7 0 10 -262144 -1 -1;
#X obj 100 155 nbx 6 14 0 99999 0 0 empty empty INDEX 0 -8 0 10 -262144 -1 -1 0 256;
#X obj 230 155 bng 30 250 50 0 empty empty LOAD 17 7 0 10 -262144 -1 -1;
#X obj 230 180 openpanel;
#X msg 230 205 read \$1;
#X obj 20 185 f 0;
#X msg 20 215 get \$1;
#X obj 20 255 oscformat /xeno/sonoscope/activations/start;
#X obj 20 285 netsend -u;
#X msg 20 315 connect 127.0.0.1 7002;
#X text 185 315 <- click once to connect;
#X connect 4 0 5 0;
#X connect 5 0 3 0;
#X connect 8 0 9 0;
#X connect 9 0 10 0;
#X connect 10 0 3 0;
#X connect 6 0 11 0;
#X connect 7 0 11 1;
#X connect 11 0 12 0;
#X connect 12 0 3 0;
#X connect 3 0 13 0;
#X connect 13 0 14 0;
#X connect 15 0 14 0;
