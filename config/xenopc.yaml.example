# xenopc.yaml — XenoPC local configuration (not committed to git).
# Copy this file to config/xenopc.yaml and fill in your values.

# Adapter name: maps to config/adapters/<adapter>.yaml
adapter: <adapter>

# Alternatively, specify an explicit adapter config path:
# adapter_config: config/adapters/<adapter>.yaml

# XenoPi connection.
xenopi_ip: 192.168.0.101
xenopi_send_port: 7001
xenopi_username: <username>
xenopi_password: <password>
xenopi_snapshots_dir: /home/<username>/xenolalia/XenoPi/snapshots

# Macroscope (XenoProjection) connection.
macroscope_ip: 127.0.0.1
macroscope_send_port: 7001

# Local server.
receive_port: 7000
local_snapshots_dir: /home/xeno/xenolalia/contents

# Debug mode: print apparatus /debug messages to console and forward to XenoProjection.
debug: false

# Named OSC targets — referenced by adapter configs (schedule, osc: side effects).
# 'xenopi' is always built-in; all others are defined here.
targets:
  # 192.168.0.100 — XenoPC (local machine)
  server:
    host: 127.0.0.1
    port: 7000
  macroscope:          # XenoProjection display
    host: 127.0.0.1
    port: 7001
  sonoscope:           # xeno_sonoscope.pd
    host: 127.0.0.1
    port: 7002
  # 192.168.0.101 — XenoPi (Raspberry Pi)
  neurons:             # xeno_osc.py (neural network server)
    host: 192.168.0.101
    port: 7000
  mesoscope:           # XenoPi Processing sketch
    host: 192.168.0.101
    port: 7001
  orbiter:             # xeno_orbiter.py (OLED)
    host: 192.168.0.101
    port: 7002
  # 192.168.0.102 — Apparatus (ESP32)
  apparatus:
    host: 192.168.0.102
    port: 7000
